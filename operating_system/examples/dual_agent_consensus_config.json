{
  "workspace": ".",
  "run_dir": ".agent_consensus/latest",
  "task_text": "Decide the exact change to make, reach consensus, then execute the configured hooks.",
  "context_files": [
    "project_memory/current_context.md",
    "docs/build_workflow.md",
    "operating_system/constraints.md"
  ],
  "max_rounds": 6,
  "agents": [
    {
      "name": "codex",
      "command": [
        "python",
        ".\\operating_system\\tools\\codex_consensus_wrapper.py",
        "--workspace",
        "{workspace}",
        "--run-dir",
        "{run_dir}",
        "--prompt-file",
        "{prompt_file}",
        "--proposal-file",
        "{proposal_file}",
        "--response-file",
        "{response_file}"
      ]
    },
    {
      "name": "claude",
      "command": [
        "python",
        ".\\operating_system\\tools\\claude_consensus_wrapper.py",
        "--workspace",
        "{workspace}",
        "--run-dir",
        "{run_dir}",
        "--prompt-file",
        "{prompt_file}",
        "--proposal-file",
        "{proposal_file}",
        "--response-file",
        "{response_file}"
      ]
    }
  ]
}
